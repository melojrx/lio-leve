#############################################
# Variáveis de Ambiente – Frontend (Vite)
# Renomeie para .env.local (gitignored) e ajuste conforme seu ambiente.
#############################################

# URL base da API Django DRF
VITE_API_BASE_URL=http://localhost:8000/api

# Nome da aplicação (usado em títulos / SEO)
VITE_APP_NAME=investorion.com.br

# Intervalo padrão de polling em ms (fallback para dados de mercado)
VITE_POLL_INTERVAL_DEFAULT=10000

# Ativa modo de mocks (quando true pode injetar dados fictícios em áreas específicas – ainda a implementar)
VITE_ENABLE_MOCKS=false

# (Adicione aqui variáveis futuras conforme necessidade)
